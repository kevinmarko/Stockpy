<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Combinatorial Purged CV & Overfitting Audit</title>
    <script src="https://cdn.plot.ly/plotly-2.24.1.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-color: #0d0f12;
            --card-bg: rgba(22, 28, 36, 0.7);
            --border-color: rgba(255, 255, 255, 0.08);
            --primary-glow: linear-gradient(135deg, #00f2fe 0%, #4facfe 100%);
            --accent-glow: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            --success-color: #00ff87;
            --danger-color: #ff007f;
            --text-main: #f5f6f8;
            --text-muted: #8a99ad;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            min-height: 100vh;
            background-image: 
                radial-gradient(circle at 10% 20%, rgba(0, 242, 254, 0.05) 0%, transparent 40%),
                radial-gradient(circle at 80% 80%, rgba(245, 87, 108, 0.05) 0%, transparent 40%);
            padding: 2rem;
            display: flex;
            justify-content: center;
        }

        .container {
            width: 100%;
            max-width: 1200px;
            display: flex;
            flex-direction: column;
            gap: 2rem;
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 1.5rem;
        }

        h1 {
            font-size: 2.2rem;
            font-weight: 800;
            background: var(--primary-glow);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .subtitle {
            color: var(--text-muted);
            margin-top: 0.25rem;
        }

        .badge {
            padding: 0.5rem 1.5rem;
            border-radius: 50px;
            font-weight: 600;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            font-size: 0.9rem;
            box-shadow: 0 0 20px rgba(0, 0, 0, 0.2);
            animation: pulse 2s infinite;
        }

        .badge-success {
            background-color: rgba(0, 255, 135, 0.1);
            color: var(--success-color);
            border: 1px solid var(--success-color);
        }

        .badge-danger {
            background-color: rgba(255, 0, 127, 0.1);
            color: var(--danger-color);
            border: 1px solid var(--danger-color);
        }

        .grid-3 {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 1.5rem;
        }

        .card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            backdrop-filter: blur(10px);
            border-radius: 16px;
            padding: 2rem;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            transition: transform 0.3s ease, border-color 0.3s ease;
        }

        .card:hover {
            transform: translateY(-4px);
            border-color: rgba(255, 255, 255, 0.15);
        }

        .card-header {
            color: var(--text-muted);
            font-size: 0.95rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 1rem;
        }

        .card-value {
            font-size: 3rem;
            font-weight: 800;
            line-height: 1;
            margin-bottom: 0.5rem;
        }

        .card-value.highlight-blue {
            background: var(--primary-glow);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .card-value.highlight-pink {
            background: var(--accent-glow);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .card-value.success {
            color: var(--success-color);
        }

        .card-value.danger {
            color: var(--danger-color);
        }

        .card-footer {
            font-size: 0.85rem;
            color: var(--text-muted);
            line-height: 1.4;
        }

        .chart-container {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 2rem;
            min-height: 450px;
        }

        .table-container {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 2rem;
            overflow-x: auto;
        }

        h2 {
            font-size: 1.5rem;
            margin-bottom: 1.5rem;
            font-weight: 600;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }

        th, td {
            padding: 1rem;
            border-bottom: 1px solid var(--border-color);
        }

        th {
            color: var(--text-muted);
            font-weight: 600;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        td {
            font-size: 0.95rem;
        }

        tr:last-child td {
            border-bottom: none;
        }

        @keyframes pulse {
            0% { box-shadow: 0 0 0 0 rgba(0, 255, 135, 0.4); }
            70% { box-shadow: 0 0 0 10px rgba(0, 255, 135, 0); }
            100% { box-shadow: 0 0 0 0 rgba(0, 255, 135, 0); }
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <div>
                <h1>Combinatorial Purged CV Report</h1>
                <div class="subtitle">InvestYo Quant Platform - Overfitting & Overselection Audit</div>
            </div>
            {% set deployable = (pbo < 0.5) and (dsr > 0.95) %}
            <div class="badge {% if deployable %}badge-success{% else %}badge-danger{% endif %}">
                {% if deployable %}DEPLOYABLE (PASS){% else %}REJECTED (FAIL){% endif %}
            </div>
        </header>

        <section class="grid-3">
            <div class="card">
                <div>
                    <div class="card-header">Deflated Sharpe Ratio (DSR)</div>
                    <div class="card-value {% if dsr > 0.95 %}success{% else %}danger{% endif %}">
                        {{ "%.2f"|format(dsr * 100) }}%
                    </div>
                </div>
                <div class="card-footer">
                    Probability that the true Sharpe Ratio is > 0, correcting for testing {{ n_trials }} strategy combinations. Target: > 95%.
                </div>
            </div>

            <div class="card">
                <div>
                    <div class="card-header">Probability of Overfitting (PBO)</div>
                    <div class="card-value {% if pbo < 0.5 %}success{% else %}danger{% endif %}">
                        {{ "%.2f"|format(pbo * 100) }}%
                    </div>
                </div>
                <div class="card-footer">
                    Probability that the selected best in-sample strategy performs below the median out-of-sample performance. Target: < 50%.
                </div>
            </div>

            <div class="card">
                <div>
                    <div class="card-header">Mean OOS Sharpe Ratio</div>
                    <div class="card-value highlight-blue">
                        {{ "%.2f"|format(mean_oos_sharpe) }}
                    </div>
                </div>
                <div class="card-footer">
                    Average out-of-sample annualized Sharpe ratio computed across all {{ paths|length }} combinatorial paths.
                </div>
            </div>
        </section>

        <section class="chart-container">
            <h2>Out-of-Sample Sharpe Distribution</h2>
            <div id="sharpe-plot" style="width: 100%; height: 350px;"></div>
        </section>

        <section class="table-container">
            <h2>Combinatorial Paths Summary</h2>
            <table>
                <thead>
                    <tr>
                        <th>Path ID (Test Splits)</th>
                        <th>OOS Sharpe Ratio</th>
                        <th>OOS Mean Return</th>
                        <th>Strategy Config Parameters</th>
                    </tr>
                </thead>
                <tbody>
                    {% for path in paths %}
                    <tr>
                        <td><strong>{{ path.path_id }}</strong></td>
                        <td style="color: {% if path.sharpe >= 0 %}#00ff87{% else %}#ff007f{% endif %};">
                            {{ "%.2f"|format(path.sharpe) }}
                        </td>
                        <td>{{ "%.2f"|format(path.returns|sum / path.returns|length * 252 * 100) }}%</td>
                        <td><code>{{ path.params }}</code></td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </section>
    </div>

    <script>
        const distribution = {{ distribution|list | tojson }};
        
        const trace = {
            x: distribution,
            type: 'histogram',
            marker: {
                color: '#4facfe',
                line: {
                    color: '#0d0f12',
                    width: 1
                }
            },
            opacity: 0.8
        };

        const layout = {
            paper_bgcolor: 'rgba(0,0,0,0)',
            plot_bgcolor: 'rgba(0,0,0,0)',
            font: {
                color: '#f5f6f8',
                family: 'Outfit, sans-serif'
            },
            xaxis: {
                title: 'Annualized Sharpe Ratio',
                gridcolor: 'rgba(255,255,255,0.05)',
                zerolinecolor: 'rgba(255,255,255,0.1)'
            },
            yaxis: {
                title: 'Frequency',
                gridcolor: 'rgba(255,255,255,0.05)',
                zerolinecolor: 'rgba(255,255,255,0.1)'
            },
            margin: { t: 20, b: 40, l: 50, r: 20 }
        };

        Plotly.newPlot('sharpe-plot', [trace], layout, {responsive: true, displayModeBar: false});
    </script>
</body>
</html>
