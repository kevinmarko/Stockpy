# InvestYo Quant Platform — runtime configuration template.
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# All keys map 1:1 to fields on the Settings class in settings.py.

# --- Secrets / credentials ---
# Required for live macroeconomic data. Get a free key:
#   https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Optional broker credentials (leave blank if unused).
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true

# --- Robinhood read-only portfolio snapshot (data/robinhood_portfolio.py) ---
# All three must be set together to enable the daily-cached portfolio fetch.
# RH_MFA_SECRET is the base32 TOTP secret from the Robinhood security page
# (Settings → Security → Two-Factor Authentication → Authenticator App → the
# 32-character code shown when setting up a new authenticator).
# NEVER commit .env — these credentials give read access to your account.
RH_USERNAME=
RH_PASSWORD=
RH_MFA_SECRET=

# --- Financial constants (override only if you know what you're doing) ---
RISK_FREE_RATE=0.045
MARKET_RISK_PREMIUM=0.055
REQUIRED_RETURN_RATE=0.08
MAX_PORTFOLIO_HEAT=0.06

# --- Position sizing (sizing/kelly.py, sizing/vol_target.py) ---
KELLY_FRACTION=0.5
KELLY_CAP=0.20
VOL_TARGET=0.10
MAX_LEVERAGE=2.0
MAX_POSITION_WEIGHT=1.0

# --- Multifactor signal (signals/multifactor.py) ---
# Tickers with Market Cap below this (USD) are excluded from cross-sectional
# z-scoring and receive a neutral score rather than fabricated factor exposure.
MULTIFACTOR_MICROCAP_THRESHOLD=300000000

# --- Runtime / IO ---
OUTPUT_DIR=./output
# JSON array of ticker symbols.
DEFAULT_TICKERS=["AAPL", "MSFT", "JNJ", "AGNC"]
LOG_LEVEL=INFO

# --- Portfolio & Watchlist Sync (data/portfolio_sync.py — Task 1.4) ---
# Colon-separated paths to additional plain-text watchlist files
# (one ticker per line; '#' = comment). Combined with every Robinhood
# "Lists" entry to form the synchronized universe surfaced by the GUI
# Live Inventory tab. Missing paths are tolerated silently.
# Example: SYNC_WATCHLIST_FILES=./watchlists/tech.txt:./watchlists/dividends.txt
SYNC_WATCHLIST_FILES=

# --- Alpaca paper-trading (execution/alpaca_broker.py) ---
# Obtain free paper-trading credentials at https://alpaca.markets/
# Leave blank to disable broker execution (orchestrator skips Step 6).
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# Set to false for live trading (default: paper=true, ALWAYS start with paper!).
ALPACA_PAPER=true

# --- Market-data layer (data/market_data.py) ---
# Optional: force a specific market-data backend.  Auto-selects when unset:
#   Alpaca (if ALPACA_API_KEY + ALPACA_SECRET_KEY are set) → yfinance (zero config).
# Valid values: "alpaca" | "yfinance"
MARKET_DATA_PROVIDER=
# Finnhub API key for fundamental data (company_basic_financials). Free tier:
#   https://finnhub.io  — degrades gracefully to yfinance .info when absent.
FINNHUB_API_KEY=
# In-process quote cache TTL in seconds (never written to disk).
# 30 s prevents redundant calls within a single refresh cycle.
MARKET_DATA_QUOTE_TTL_SECONDS=30
# In-process fundamentals cache TTL in seconds (never written to disk).
# 21600 (6 h) is safe since fundamentals are quarterly; both positive AND empty
# (e.g. 429-rate-limited) responses are cached so neither Finnhub nor yfinance
# is re-hammered within the window.
FUNDAMENTALS_CACHE_TTL_SECONDS=21600
# Sliding-window call budget for Finnhub (per 60 s).  Free tier ceiling is 60;
# defaulting to 50 leaves headroom for the auxiliary quote / company_profile2
# endpoints invoked by get_fundamentals.
FINNHUB_RATE_LIMIT_PER_MIN=50

# --- Robinhood legacy integration (data/robinhood_client.py — SMS-based login) ---
# Used to fetch holdings and generate custom advice via the legacy client.
ROBINHOOD_USERNAME=
ROBINHOOD_PASSWORD=

# --- Robinhood portfolio snapshot (data/robinhood_portfolio.py — TOTP login) ---
# Read-only account snapshot with daily caching. No order functions.
# RH_MFA_SECRET: the Base32 secret shown on the Robinhood MFA setup page.
# Enable authenticator-app MFA on your account, then copy the raw secret here.
RH_USERNAME=
RH_PASSWORD=
RH_MFA_SECRET=

# --- Order management (execution/order_manager.py) ---
# Set DRY_RUN=true to log intended orders without submitting them.
# Also toggleable via CLI: python3 main_orchestrator.py --dry-run
DRY_RUN=false
# Optional Slack / Discord incoming-webhook URL for reconciliation drift alerts.
ALERT_WEBHOOK_URL=

# --- Pre-trade risk gate (execution/risk_gate.py) ---
# Max absolute pairwise return correlation before a new position is blocked.
MAX_CORRELATION=0.85
# Halt new BUY orders when intraday P&L drops below this fraction of start-of-day equity.
DAILY_LOSS_LIMIT_PCT=0.02
# Maximum order submissions in any 60-second rolling window.
MAX_ORDER_RATE_PER_MIN=10
# Block new long orders when HMM risk-off probability exceeds this.
HMM_RISK_OFF_BLOCK_THRESHOLD=0.80
# Set to false to allow orders outside NYSE RTH (09:30–16:00 ET).
RISK_GATE_ENFORCE_MARKET_HOURS=true
# Macro Regime Gate: when true (default), MacroEconomicDTO.killSwitch vetoes new
# BUY orders during RECESSION/CREDIT EVENT regimes (Sahm Rule ≥ 0.5, VIX > 30,
# or HY OAS > 6%).  Set false to let technical signals run during idiosyncratic
# volatility that triggers a systemic false positive (hybrid mode).
# WARNING: always re-enable before going live — preflight_check.py will fail
# if this is false AND ALPACA_PAPER=false.
# The GUI Observability tab's "Macro Regime Gate" toggle writes this value.
MACRO_REGIME_GATE_ENABLED=true

# --- Kill switch (execution/kill_switch.py) ---
# When true and the kill switch fires, a CRITICAL log message reminds you to flatten
# all open positions manually. Automatic flattening is a future extension.
FLATTEN_ON_KILL=false

# --- Push notifications via ntfy.sh (alerting.py) ---
# Free, open-source push notifications — no account required for public topics.
# 1. Install the ntfy app on your phone (iOS / Android — search "ntfy").
# 2. Set a random, unguessable topic name below (e.g. "investyo-abc123xyz").
# 3. In the ntfy app, subscribe to that exact topic name.
# When NTFY_TOPIC is unset, notify() is a no-op (app still runs fine).
# HIGH-priority alerts fire for any per-symbol pipeline error.
# DEFAULT-priority "refresh complete" alert fires once per launch (not per tick).
# See docs/HOW_TO_GUIDE.md §14 for full setup instructions.
NTFY_TOPIC=

# --- Advisory rationale verbosity (engine/advisory.py, Task 1.5) ---
# Controls how much narrative detail the per-symbol advisory rationale includes.
# "standard" (default) = one terse paragraph citing the top 2-3 drivers.
# "verbose"             = standard paragraph PLUS four annotated sections:
#   [A] Regime context  — HMM probability + FRED macro snapshot
#   [B] Calibration     — strategy win-rate and Kelly edge from closed trades
#   [C] Invalidation    — explicit flip points that would void the recommendation
#   [D] Theory notes    — first-line __doc__ of each active signal module
# Verbose mode is intended for compliance review and high-stakes discretionary
# overrides where full institutional narrative is required.
RATIONALE_VERBOSITY=standard

# --- Symbol watch alerts (watch_engine.py, Tier 1.4) ---
# Path to the YAML file defining per-symbol watch alert rules.
# Default: watch_rules.yaml in the project root (already provided).
# Set to a different path if you keep your rules outside the repo.
WATCH_RULES_FILE=watch_rules.yaml
# Optional deep-link URL appended to every watch notification body.
# Useful for jumping straight from a phone notification to the dashboard.
# Example (local machine): NTFY_DASHBOARD_URL=http://localhost:8501
NTFY_DASHBOARD_URL=

# --- Observability / alerts (observability/alerts.py) ---
# Discord incoming-webhook URL (Settings → Integrations → Webhooks in a channel).
DISCORD_WEBHOOK_URL=
# Slack incoming-webhook URL (https://api.slack.com/messaging/webhooks).
SLACK_WEBHOOK_URL=
# Absolute path for the JSON-lines alert log file. Leave blank to disable file logging.
ALERT_FILE_PATH=
# Email sender address for SMTP alerts.
ALERT_EMAIL_FROM=
# Comma-separated recipient addresses.
ALERT_EMAIL_TO=
# SMTP server settings (587 = STARTTLS).
ALERT_SMTP_HOST=
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=
ALERT_SMTP_PASSWORD=
# Dashboard auto-refresh interval in seconds (default 1800 = 30 min).
# Range: 30–7200. Set lower only when actively watching an open position.
DASHBOARD_REFRESH_SECONDS=1800

# --- Pre-live readiness (scripts/preflight_check.py) ---
# ISO date (YYYY-MM-DD) when paper trading began. Required by preflight check #13.
PAPER_TRADING_START_DATE=
# ISO date (YYYY-MM-DD) when FRED_API_KEY was last rotated.
# Set this after generating a new key at https://fred.stlouisfed.org/docs/api/api_key.html
# Optional — when unset, preflight warns that rotation tracking isn't active (check #2).
# Example: FRED_KEY_ROTATED_DATE=2026-06-01
FRED_KEY_ROTATED_DATE=

# --- Key-rotation reminders (checks 2 + 3 in scripts/preflight_check.py) ---
# Set each to the ISO date (YYYY-MM-DD) when you last rotated the corresponding
# API key.  Both checks are warning-only (never blocking); leaving them blank
# is safe but will produce a reminder in the preflight output.
# ALPACA_KEY_ROTATED_DATE is auto-skipped when ADVISORY_ONLY=True (Alpaca keys
# have no blast-radius risk while the broker surface is quarantined).
FRED_KEY_ROTATED_DATE=
ALPACA_KEY_ROTATED_DATE=

# --- Signal module enable/disable (gui/ Command Center, signals/aggregator.py) ---
# JSON array of signal-module names to exclude from SignalAggregator.aggregate().
# Empty list = all registered modules contribute (legacy behavior). The Command
# Center's Strategy Matrix tab writes this for you; honored by both orchestrators.
# Example: DISABLED_SIGNAL_MODULES=["rsi2_mean_reversion"]
DISABLED_SIGNAL_MODULES=[]

# --- "Δ Since Last Run" snapshot rotation (scripts/snapshot_diff.py) ---
# Rotated state-snapshot files under output/history/ older than this many
# days are pruned on every run. 0 disables pruning. Default: 30.
SNAPSHOT_HISTORY_DAYS=30
# |Δ advisory_conviction| at or above this surfaces in the daily HTML
# report's "Δ Since Last Run" band. Default: 0.2.
SNAPSHOT_CONVICTION_DELTA_THRESHOLD=0.2
