# InvestYo Quant Platform — runtime configuration template.
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# All keys map 1:1 to fields on the Settings class in settings.py.

# --- Secrets / credentials ---
# Required for live macroeconomic data. Get a free key:
#   https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Optional broker credentials (leave blank if unused).

# --- Robinhood read-only portfolio snapshot (data/robinhood_portfolio.py) ---
# All three must be set together to enable the daily-cached portfolio fetch.
# RH_MFA_SECRET is the base32 TOTP secret from the Robinhood security page
# (Settings → Security → Two-Factor Authentication → Authenticator App → the
# 32-character code shown when setting up a new authenticator).
# NEVER commit .env — these credentials give read access to your account.

# --- Financial constants (override only if you know what you're doing) ---
RISK_FREE_RATE=0.045
MARKET_RISK_PREMIUM=0.055
REQUIRED_RETURN_RATE=0.08
MAX_PORTFOLIO_HEAT=0.06

# --- Position sizing (sizing/kelly.py, sizing/vol_target.py) ---
KELLY_FRACTION=0.5
KELLY_CAP=0.20
VOL_TARGET=0.10
MAX_LEVERAGE=2.0
MAX_POSITION_WEIGHT=1.0

# --- Multifactor signal (signals/multifactor.py) ---
# Tickers with Market Cap below this (USD) are excluded from cross-sectional
# z-scoring and receive a neutral score rather than fabricated factor exposure.
MULTIFACTOR_MICROCAP_THRESHOLD=300000000

# --- Meta-labeling (ml/meta_labeling.py) ---
# Master switch for the runtime registration of trained meta-labelers at
# startup (ml/meta_bootstrap.py). No-op when no saved model exists.
META_LABELING_ENABLED=true
# Hard gate: if a registered MetaLabeler's P(signal correct) falls below this,
# meta_label_composite is forced to 0.0 (position zeroed for the cycle).
META_LABEL_MIN_CONFIDENCE=0.4

# --- Database Backend (db_config.py — dual-backend seam) ---
# Full SQLAlchemy connection URL. Leave blank to use the local
# quant_platform.db SQLite file (today's behavior, unchanged). Set to a
# postgresql://user:pass@host/db URL to move trades/iv_history to Postgres.
# May embed credentials — never logged. Pool settings apply to Postgres only.
DATABASE_URL=
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# --- Historical Persistence (data/historical_store.py, Tier 2.3) ---
# Master flag for HistoricalStore DB routing (OHLCV bars, account snapshots,
# fundamentals, FRED macro series backed by quant_platform.db).
HISTORICAL_STORE_ENABLED=true
# Calendar days to backfill on first-ever fetch for a symbol (~2 years).
BARS_BACKFILL_DAYS=504
# Max age (days) of a cached fundamentals row before it is refetched.
FUNDAMENTALS_REFRESH_DAYS=1
# Min age (hours) of the most-recent macro_history row before a FRED top-up.
MACRO_REFRESH_HOURS=12
# Writes today's cross-sectional PIT feature snapshot for future ML retrains.
# Dead-lettered: capture failures are logged and never crash the pipeline.
PIT_CAPTURE_ENABLED=true

# --- Runtime / IO ---
OUTPUT_DIR=./output
# JSON array of ticker symbols.
DEFAULT_TICKERS=["AAPL", "MSFT", "JNJ", "AGNC"]
LOG_LEVEL=INFO

# --- State API CORS (api/state_api.py) ---
# JSON array of browser origins allowed to call the State API. Lock to your frontend URL(s).
CORS_ALLOWED_ORIGINS=["http://localhost:3000"]

# --- Concurrency (data_engine.py, main_orchestrator.py, main.py,
#     scripts/backfill_edgar_fundamentals.py) ---
# Worker-thread counts for the parallelized per-symbol/per-ticker loops. The
# first three default to 8; EDGAR defaults to 4 (LOWER on purpose — its
# companyfacts payloads are 50-150 MB each, so it's a memory knob, and its own
# throttle — not the worker count — enforces SEC's ≤10 req/s limit). Set any to
# 1 to force the original sequential, fully-deterministic path. Results are
# always reassembled in deterministic symbol order.
ADVISORY_MAX_CONCURRENCY=8
FORECAST_MAX_CONCURRENCY=8
DATA_FETCH_MAX_CONCURRENCY=8
EDGAR_MAX_CONCURRENCY=4

# --- Forecasting engine tunables (forecasting_engine.py) ---
# Use the GJR-GARCH(1,1) volatility estimate as the Monte Carlo sigma instead
# of naive historical stdev. false restores the pre-GARCH behavior.
FORECAST_USE_GARCH_SIGMA=true
# Weight given to the Prophet 30-day forecast in the ensemble blend at the
# 30-day horizon: final = base*(1-w) + prophet*w. 0.0 disables Prophet.
FORECAST_PROPHET_WEIGHT=0.25
# Opt-in: persist trained CNN-LSTM/Prophet models to disk per ticker instead
# of retraining from scratch every cycle (forecasting/model_persistence.py).
FORECAST_MODEL_PERSISTENCE_ENABLED=false
# Days a persisted model artifact remains valid before the next call for that
# ticker triggers a fresh fit. Only consulted when persistence is enabled.
FORECAST_MODEL_RETRAIN_DAYS=7
# Opt-in, OUTPUT-CHANGING: inverse-RMSE skill-weighted multi-model forecast
# blending (ARIMA/Monte Carlo/Holt-Winters/CNN-LSTM weighted by recent
# realized accuracy). false (default) uses the static sector-preference blend.
FORECAST_SKILL_WEIGHTING_ENABLED=false
# Rolling window (days) over which per-model RMSE is computed. MUST exceed
# the max forecast horizon (90d) or long horizons can never warm up.
FORECAST_SKILL_WINDOW_DAYS=180
# Minimum completed (actualized) forecast rows per model before skill-based
# weighting activates; below this, all models get equal weight (cold-start).
FORECAST_SKILL_MIN_OBS=30
# Opt-in, OUTPUT-CHANGING: main_orchestrator.py's advisory overlay reuses
# run_pipeline's already-fit GARCH/forecast values instead of refitting a
# second time per ticker per cycle. false (default) = always refit independently.
ADVISORY_REUSE_PIPELINE_COMPUTE=false

# --- Per-Sector Forecast Model/Horizon Config ---
# Path to the committed per-sector forecast config artifact (derived from an
# offline walk-forward backtest — see validation/sector_forecast_backtest.py).
SECTOR_FORECAST_CONFIG_PATH=forecasting/sector_configs.json
# Optional per-sector override merged OVER the artifact/hardcoded default.
# JSON dict, e.g. {"Technology": {"days": 30, "model": "MC"}}. Empty = no override.
SECTOR_FORECAST_CONFIGS={}

# --- Signal weights (signals/aggregator.py) ---
# JSON dict overriding the per-module weights hardcoded as the Settings
# default (see settings.py SIGNAL_WEIGHTS for the full default dict). Leave
# blank/unset to use the built-in defaults — only set this to override.
# SIGNAL_WEIGHTS={"macro_regime": 45.0, "graham_value": 15.0}
#
# Optional per-regime weight overrides merged onto SIGNAL_WEIGHTS for the
# current macro regime. Empty dict (default) = flat weights for all regimes.
# REGIME_SIGNAL_WEIGHTS={"RECESSION": {"rsi2_mean_reversion": 0.0}}

# --- Portfolio & Watchlist Sync (data/portfolio_sync.py — Task 1.4) ---
# Colon-separated paths to additional plain-text watchlist files
# (one ticker per line; '#' = comment). Combined with every Robinhood
# "Lists" entry to form the synchronized universe surfaced by the GUI
# Live Inventory tab. Missing paths are tolerated silently.
# Example: SYNC_WATCHLIST_FILES=./watchlists/tech.txt:./watchlists/dividends.txt
SYNC_WATCHLIST_FILES=

# --- Alpaca paper-trading (execution/alpaca_broker.py) ---
# Obtain free paper-trading credentials at https://alpaca.markets/
# Leave blank to disable broker execution (orchestrator skips Step 6).
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# Set to false for live trading (default: paper=true, ALWAYS start with paper!).
ALPACA_PAPER=true

# --- Robinhood execution bridge (Tier 8 — execution/queue_builder.py + execution/compose.py) ---
# Independent of ADVISORY_ONLY (which gates the Alpaca surface). Governs whether
# the pipeline emits a gated, dry-run output/execution_queue.json for the Claude
# Code "robinhood-execution" agent (which is the only actor that calls the
# Robinhood Trading MCP). Rollout is strictly off -> review -> live.
#   off    = (default) emit nothing; zero behaviour change.
#   review = paper/dry-run; agent only simulates via review_equity_order.
#   live   = real placement possible (agent still requires per-trade human confirm).
ROBINHOOD_EXECUTION_MODE=off
# Hard per-order USD notional ceiling used when building the queue. 0 = unset;
# 'live' REQUIRES a value > 0 (preflight fails otherwise).
ROBINHOOD_MAX_NOTIONAL_PER_ORDER=0
# Limit-order buffer in basis points (1 bps = 0.01%) for the execution queue.
#   0 = (default) MARKET orders — byte-identical to legacy behaviour.
#   >0 = LIMIT orders; each intent gains `limit_offset_bps` and `order_type=limit`.
# The actual limit_price stays null in the queue; the robinhood-execution skill
# resolves it from a live MCP quote at review time:
#   BUY  limit <= quote * (1 + bps/10000)   SELL limit >= quote * (1 - bps/10000)
ROBINHOOD_LIMIT_BUFFER_BPS=0
# Max age (seconds) of an output/queue_sources/*.json file (the advisory pipeline's
# own source, or an actively-followed Pilot's) before execution/compose.py refuses
# to compose (writes nothing, leaves the last known-good execution_queue.json in
# place) rather than netting against stale data. 604800 = 7 days, a deliberate,
# conservative judgment call — not a derived constant.
QUEUE_SOURCE_MAX_AGE_SECONDS=604800

# --- Market-data layer (data/market_data.py) ---
# Optional: force a specific market-data backend.  Auto-selects when unset:
#   Alpaca (if ALPACA_API_KEY + ALPACA_SECRET_KEY are set) → yfinance (zero config).
# Valid values: "alpaca" | "yfinance"
MARKET_DATA_PROVIDER=
# FINNHUB_API_KEY is now used ONLY by the news_catalyst signal (company news /
#   earnings headlines), NOT for fundamentals — fundamentals are Yahoo
#   statement-derived (data/yahoo_fundamentals.py) with a yfinance .info
#   fallback. Free tier: https://finnhub.io. Absent = news_catalyst disabled;
#   no effect on fundamentals.
FINNHUB_API_KEY=
# In-process quote cache TTL in seconds (never written to disk).
# 30 s prevents redundant calls within a single refresh cycle.
MARKET_DATA_QUOTE_TTL_SECONDS=30
# In-process fundamentals cache TTL in seconds (never written to disk).
# 21600 (6 h) is safe since fundamentals are quarterly; both positive AND empty
# (e.g. 429-rate-limited) responses are cached so neither Finnhub nor yfinance
# is re-hammered within the window.
FUNDAMENTALS_CACHE_TTL_SECONDS=21600
# Shorter TTL specifically for NEGATIVE (empty-dict) fundamentals responses —
# a provider that was rate-limited or briefly down re-tries much sooner than
# a genuinely positive result (default 15 min vs. the 6 h positive TTL above).
FUNDAMENTALS_NEG_CACHE_TTL_SECONDS=900
# In-process OHLCV intraday-bars cache TTL in seconds (never written to disk).
# Bars are daily-resolution, so a few-minutes TTL collapses the repeated
# per-symbol history fetches (universe pre-fetch + advisory refetch + GUI
# panels) into a single network pull within the window.
MARKET_DATA_BARS_TTL_SECONDS=300
# Sliding-window call budget for Finnhub (per 60 s).  Free tier ceiling is 60;
# defaulting to 50 leaves headroom for the auxiliary quote / company_profile2
# endpoints invoked by get_fundamentals.
FINNHUB_RATE_LIMIT_PER_MIN=50
# Trailing calendar days of daily returns used to compute beta in the
# Yahoo-derived fundamentals engine (Cov(stock,SPY)/Var(SPY)). ~2 years.
# BETA_LOOKBACK_DAYS=504
# Primary fundamentals backend: "yahoo" (statement-derived, default) or
# "yfinance_info" (raw .info fallback). Finnhub is no longer a fundamentals source.
# FUNDAMENTALS_SOURCE=yahoo

# --- News Catalyst Signal (Tier 2.4, signals/news_catalyst.py) ---
# Calendar days of Finnhub company_news headlines to score per symbol per cycle.
NEWS_LOOKBACK_DAYS=7
# When true and `transformers` is installed, uses ProsusAI/FinBERT for
# headline sentiment; false (or transformers unavailable) uses a keyword
# lexicon fallback instead — set false to avoid the ~200MB model download.
FINBERT_ENABLED=true
# Hours before next earnings within which the news catalyst score is forced
# to 0.0 (pre-earnings headlines are unreliable — outcome isn't observable yet).
NEWS_EARNINGS_SUPPRESS_HOURS=48.0
# Days before next earnings within which the score is dampened by 50%.
NEWS_EARNINGS_DAMPEN_DAYS=7.0

# --- Correlation Cluster Awareness (Tier 2.5, research_engine.py) ---
# On-demand hierarchical clustering computed in the GUI Reports tab only
# (the orchestrator does not run cluster analysis automatically).
CORRELATION_CLUSTER_LOOKBACK_DAYS=60
CORRELATION_CLUSTER_THRESHOLD=0.4

# --- Dual Momentum allocator overlay ---
# When true, the Dual Momentum allocator pre-screens tickers each run — if it
# selects the safe asset, risky-universe tickers have Kelly Target set to 0.0.
USE_DUAL_MOMENTUM_OVERLAY=false
DUAL_MOMENTUM_SAFE_ASSET=BIL
DUAL_MOMENTUM_RISKY_ASSETS=["SPY", "VEU"]

# --- Robinhood legacy integration (data/robinhood_client.py — SMS-based login) ---
# Used to fetch holdings and generate custom advice via the legacy client.
ROBINHOOD_USERNAME=
ROBINHOOD_PASSWORD=

# --- Robinhood portfolio snapshot (data/robinhood_portfolio.py — TOTP login) ---
# Read-only account snapshot with daily caching. No order functions.
# RH_MFA_SECRET: the Base32 secret shown on the Robinhood MFA setup page.
# Enable authenticator-app MFA on your account, then copy the raw secret here.
RH_USERNAME=
RH_PASSWORD=
RH_MFA_SECRET=

# ROBINHOOD_AUTO_REFRESH_ENABLED: true (default) preserves the existing daily-cache
# behavior — fetch_account_snapshot() auto-logs-in whenever the cache exceeds
# max_age_hours (20h default), from ANY caller (GUI panels, MCP server, Pilots/data
# APIs, portfolio_sync, llm_commentary). Set false to make login strictly opt-in:
# only `python3 main.py --refresh-account` ever logs in; every other caller gets the
# best available cached snapshot regardless of staleness. Useful if repeated
# automated login attempts are triggering Robinhood security checks/lockouts.
ROBINHOOD_AUTO_REFRESH_ENABLED=true

# --- Advisory-only mode (Tier 5.1) ---
# When true (the project default), ALL broker order submission is suppressed —
# the pipeline still runs end-to-end (signals, sizing, HTML report, JSON
# payload) but main_orchestrator._execute_broker_orders() returns immediately
# and the GUI Strategy Matrix execution-mode toggle is disabled. This is a
# HARDER guarantee than DRY_RUN (enforced at the orchestrator gate, not just
# inside OrderManager). Set false ONLY when you have explicitly re-enabled the
# broker stack and intend to submit orders (both ADVISORY_ONLY=false AND
# DRY_RUN=false AND ALPACA_PAPER=false must agree to reach live submission).
ADVISORY_ONLY=true

# --- Order management (execution/order_manager.py) ---
# Set DRY_RUN=true to log intended orders without submitting them.
# Also toggleable via CLI: python3 main_orchestrator.py --dry-run
DRY_RUN=false
# Optional Slack / Discord incoming-webhook URL for reconciliation drift alerts.
ALERT_WEBHOOK_URL=

# --- State API security (api/state_api.py) ---
# Bearer token for the read-only FastAPI state service. When set, /state, /signals,
# and /trades require an "Authorization: Bearer <token>" header. When blank, those
# endpoints are UNAUTHENTICATED (fine for local-only use; set a token before exposing).
# Generate one:  python -c "import secrets; print(secrets.token_urlsafe(32))"
STATE_API_TOKEN=

# --- Pilots API (api/pilots_api.py, port 8602) — the Autopilot-style PWA backend ---
# The Pilots READ endpoints reuse STATE_API_TOKEN above (fail-open when blank).
# FOLLOW_API_TOKEN gates the follow WRITE-path (GET/PUT /follows, POST
# /pilots/{id}/follow) and is FAIL-CLOSED: when blank those endpoints are DISABLED
# (403 on every call), since a follow triggers the gated order queue. Set to enable.
FOLLOW_API_TOKEN=
# Max holdings surfaced per Pilot (top-N by blended score).
PILOTS_TOP_N=20
# Enables the Pilots API's brokerage-credential intake endpoints
# (POST /brokerage/connect, POST /brokerage/disconnect — data/brokerage_credentials.py),
# used by the PWA onboarding flow's "Connect Robinhood" option. Off by default —
# a deliberate departure from this project's normal hand-edit-.env posture for
# secrets, so it must be explicitly opted into. Also requires FOLLOW_API_TOKEN
# (reused from the follow write-path) AND a loopback (127.0.0.1) request — three
# independent gates. GET /brokerage/status is read-only and NOT gated by this flag.
# Local single-operator model only — not a multi-user credential vault.
BROKERAGE_CONNECT_ENABLED=false
# Master switch for the Pilots API's Data & Automation WRITE endpoints that
# have a real persistence/rollback cost: PUT /automation/schedule/interval
# (an .env edit) and POST /automation/resume (re-enabling live order
# submission while ADVISORY_ONLY=false). Off by default; also requires
# FOLLOW_API_TOKEN (reused from the follow write-path). Never GUI-writable —
# hand-set only. POST /automation/run and /automation/pause are NOT gated by
# this flag (require_command_token alone, matching the follow write-path's
# existing risk posture: gating a run trigger or pause more strictly than the
# most sensitive endpoint already shipped would invert the risk ordering).
AUTOMATION_WRITES_ENABLED=false

# --- Persistent orchestrator daemon (desktop/orchestrator_daemon.py, api/control_api.py) ---
# Cutover flag: false (default) preserves today's exact subprocess behavior —
# the desktop shell spawns `main.py --interval N` and the GUI Launcher tab
# spawns a fresh `main_orchestrator.py` per click. true switches both to the
# always-on warm daemon (heavy engines stay constructed across cycles).
ORCHESTRATOR_DAEMON_ENABLED=false
# Seconds between automatic daemon cycles. 0 (default) = on-demand only (no
# internal timer); overridable via the daemon entrypoint's --interval flag.
ORCHESTRATOR_INTERVAL_SECONDS=0
# TCP port the daemon's Control API binds to (loopback-only, 127.0.0.1).
ORCHESTRATOR_API_PORT=8601
# Bearer token guarding POST /run on the Control API. FAIL-CLOSED: unset means
# the command endpoint is disabled entirely (403), not open — triggering a
# real pipeline run is a materially different risk than reading state.
# Generate one:  python -c "import secrets; print(secrets.token_urlsafe(32))"
ORCHESTRATOR_DAEMON_TOKEN=

# --- Pre-trade risk gate (execution/risk_gate.py) ---
# Max absolute pairwise return correlation before a new position is blocked.
MAX_CORRELATION=0.85
# Halt new BUY orders when intraday P&L drops below this fraction of start-of-day equity.
DAILY_LOSS_LIMIT_PCT=0.02
# Maximum order submissions in any 60-second rolling window.
MAX_ORDER_RATE_PER_MIN=10
# Block new long orders when HMM risk-off probability exceeds this.
HMM_RISK_OFF_BLOCK_THRESHOLD=0.80
# Set to false to allow orders outside NYSE RTH (09:30–16:00 ET).
RISK_GATE_ENFORCE_MARKET_HOURS=true

# --- HMM regime detector (regime/hmm_regime.py, macro_engine.py) ---
# Number of hidden states for the Gaussian HMM regime detector (bull/sideways/bear).
HMM_N_STATES=3
# Minimum days between HMM refits; fit() calls within this window of the last
# real fit are no-ops (expanding-window fitting is the caller's responsibility).
HMM_RETRAIN_FREQ_DAYS=7
# Macro Regime Gate: when true (default), MacroEconomicDTO.killSwitch vetoes new
# BUY orders during RECESSION/CREDIT EVENT regimes (Sahm Rule ≥ 0.5, VIX > 30,
# or HY OAS > 6%).  Set false to let technical signals run during idiosyncratic
# volatility that triggers a systemic false positive (hybrid mode).
# WARNING: always re-enable before going live — preflight_check.py will fail
# if this is false AND ALPACA_PAPER=false.
# The GUI Observability tab's "Macro Regime Gate" toggle writes this value.
MACRO_REGIME_GATE_ENABLED=true

# --- Kill switch (execution/kill_switch.py) ---
# When true and the kill switch fires, a CRITICAL log message reminds you to flatten
# all open positions manually. Automatic flattening is a future extension.
FLATTEN_ON_KILL=false

# --- Push notifications via ntfy.sh (alerting.py) ---
# Free, open-source push notifications — no account required for public topics.
# 1. Install the ntfy app on your phone (iOS / Android — search "ntfy").
# 2. Set a random, unguessable topic name below (e.g. "investyo-abc123xyz").
# 3. In the ntfy app, subscribe to that exact topic name.
# When NTFY_TOPIC is unset, notify() is a no-op (app still runs fine).
# HIGH-priority alerts fire for any per-symbol pipeline error.
# DEFAULT-priority "refresh complete" alert fires once per launch (not per tick).
# See docs/HOW_TO_GUIDE.md §14 for full setup instructions.
NTFY_TOPIC=

# --- Advisory rationale verbosity (engine/advisory.py, Task 1.5) ---
# Controls how much narrative detail the per-symbol advisory rationale includes.
# "standard" (default) = one terse paragraph citing the top 2-3 drivers.
# "verbose"             = standard paragraph PLUS four annotated sections:
#   [A] Regime context  — HMM probability + FRED macro snapshot
#   [B] Calibration     — strategy win-rate and Kelly edge from closed trades
#   [C] Invalidation    — explicit flip points that would void the recommendation
#   [D] Theory notes    — first-line __doc__ of each active signal module
# Verbose mode is intended for compliance review and high-stakes discretionary
# overrides where full institutional narrative is required.
RATIONALE_VERBOSITY=standard

# --- Symbol watch alerts (watch_engine.py, Tier 1.4) ---
# Path to the YAML file defining per-symbol watch alert rules.
# Default: watch_rules.yaml in the project root (already provided).
# Set to a different path if you keep your rules outside the repo.
WATCH_RULES_FILE=watch_rules.yaml
# Optional deep-link URL appended to every watch notification body.
# Useful for jumping straight from a phone notification to the dashboard.
# Example (local machine): NTFY_DASHBOARD_URL=http://localhost:8501
NTFY_DASHBOARD_URL=

# --- Observability / alerts (observability/alerts.py) ---
# Discord incoming-webhook URL (Settings → Integrations → Webhooks in a channel).
DISCORD_WEBHOOK_URL=
# Slack incoming-webhook URL (https://api.slack.com/messaging/webhooks).
SLACK_WEBHOOK_URL=
# Absolute path for the JSON-lines alert log file. Leave blank to disable file logging.
ALERT_FILE_PATH=
# Email sender address for SMTP alerts.
ALERT_EMAIL_FROM=
# Comma-separated recipient addresses.
ALERT_EMAIL_TO=
# SMTP server settings (587 = STARTTLS).
ALERT_SMTP_HOST=
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=
ALERT_SMTP_PASSWORD=

# --- alerting_mcp push notifier (alerting_mcp/notifier.py) ---
# Separate subsystem from observability/alerts.py above. Note the distinct
# ALERT_EMAIL_SMTP_* names (vs ALERT_SMTP_* used by observability/alerts.py).
# Comma-separated active channels; unset defaults to 'ntfy'. e.g. ntfy,email,slack
ALERT_CHANNELS=
# ntfy.sh topic for push notifications; unset disables the ntfy channel.
ALERT_NTFY_TOPIC=
# SMTP settings for the notifier's email channel (587 = STARTTLS).
ALERT_EMAIL_SMTP_HOST=
ALERT_EMAIL_SMTP_PORT=587
# SMTP app-password (secret); unset disables the email channel.
ALERT_EMAIL_SMTP_PASSWORD=
# Slack incoming-webhook URL (secret); unset disables the Slack channel.
ALERT_SLACK_WEBHOOK_URL=
# Dashboard auto-refresh interval in seconds (default 1800 = 30 min).
# Range: 30–7200. Set lower only when actively watching an open position.
DASHBOARD_REFRESH_SECONDS=1800
# Poll interval (seconds) for the Launcher live pipeline-progress bar.
PROGRESS_POLL_SECONDS=5

# --- Pre-live readiness (scripts/preflight_check.py) ---
# ISO date (YYYY-MM-DD) when paper trading began. Required by preflight check #13.
PAPER_TRADING_START_DATE=
# ISO date (YYYY-MM-DD) when FRED_API_KEY was last rotated.
# Set this after generating a new key at https://fred.stlouisfed.org/docs/api/api_key.html
# Optional — when unset, preflight warns that rotation tracking isn't active (check #2).
# Example: FRED_KEY_ROTATED_DATE=2026-06-01

# --- Key-rotation reminders (checks 2 + 3 in scripts/preflight_check.py) ---
# Set each to the ISO date (YYYY-MM-DD) when you last rotated the corresponding
# API key.  Both checks are warning-only (never blocking); leaving them blank
# is safe but will produce a reminder in the preflight output.
# ALPACA_KEY_ROTATED_DATE is auto-skipped when ADVISORY_ONLY=True (Alpaca keys
# have no blast-radius risk while the broker surface is quarantined).
FRED_KEY_ROTATED_DATE=
ALPACA_KEY_ROTATED_DATE=

# --- Signal module enable/disable (gui/ Command Center, signals/aggregator.py) ---
# JSON array of signal-module names to exclude from SignalAggregator.aggregate().
# Empty list = all registered modules contribute (legacy behavior). The Command
# Center's Strategy Matrix tab writes this for you; honored by both orchestrators.
# Example: DISABLED_SIGNAL_MODULES=["rsi2_mean_reversion"]
DISABLED_SIGNAL_MODULES=[]

# --- "Δ Since Last Run" snapshot rotation (scripts/snapshot_diff.py) ---
# Rotated state-snapshot files under output/history/ older than this many
# days are pruned on every run. 0 disables pruning. Default: 30.
SNAPSHOT_HISTORY_DAYS=30
# |Δ advisory_conviction| at or above this surfaces in the daily HTML
# report's "Δ Since Last Run" band. Default: 0.2.
SNAPSHOT_CONVICTION_DELTA_THRESHOLD=0.2

# ── AI Control Center (Tier 9 — Claude / Gemini / Opal / Gravity AI runner) ──
# Every switch below defaults to OFF/unset: zero SDK imports, zero network
# calls, byte-identical behavior to a platform with no AI keys configured.
# All can also be flipped from the GUI's "🎛️ AI Control Center" tab; the API
# keys themselves are secrets and must be set here by hand (never GUI-writable
# — CONSTRAINT #3).
#
# NON-SECRET tunables (GUI-writable):
# ─────────────────────────────────────────────────────────────────────────────
# Master switch for on-demand per-symbol analyst rationale + alert commentary.
LLM_COMMENTARY_ENABLED=false
# Provider for rationale generation: "claude" (default) | "gemini" | "none".
LLM_COMMENTARY_RATIONALE_PROVIDER=claude
# Provider for alert-text generation: "gemini" (default) | "claude" | "none".
# Independent of LLM_COMMENTARY_RATIONALE_PROVIDER — mix and match freely.
LLM_COMMENTARY_ALERT_PROVIDER=gemini
# JSON cache for LLM commentary results (day-bucketed; safe to delete manually).
LLM_COMMENTARY_CACHE_PATH=output/llm_commentary_cache.json
# Hard wall-clock timeout (seconds) per provider call. Exceeding it counts as
# a soft failure (returns None; caller falls back to the deterministic template).
LLM_COMMENTARY_TIMEOUT_SECONDS=8
# Master switch for Opal, the OpenAI/GPT front-of-pipeline research agent.
# Independent of LLM_COMMENTARY_ENABLED.
OPAL_RESEARCH_ENABLED=false
# Provider for Opal: "openai" (default, only supported provider) | "none".
OPAL_RESEARCH_PROVIDER=openai
# OpenAI model used for Opal's structured research-brief calls.
OPAL_RESEARCH_MODEL=gpt-4o
# Hard wall-clock timeout (seconds) per Opal call. Exceeding it counts as a
# soft failure (returns None; caller skips Opal for this cycle).
OPAL_RESEARCH_TIMEOUT_SECONDS=15
# Master switch for the AI Gravity audit runner (Claude auditor + Gemini
# cross-checker over the 7-step audit prompts). Independent of the two above.
GRAVITY_AI_RUNNER_ENABLED=false
# Where the runner writes the per-step Claude + Gemini verdicts.
GRAVITY_AI_RUNNER_OUTPUT_PATH=output/gravity_ai_audit.json
#
# SECRET credentials (NOT GUI-writable; edit this file by hand only):
# ─────────────────────────────────────────────────────────────────────────────
# Anthropic API key — https://console.anthropic.com/settings/keys
# Required whenever LLM_COMMENTARY_RATIONALE_PROVIDER, LLM_COMMENTARY_ALERT_PROVIDER,
# or GRAVITY_AI_RUNNER_ENABLED routes to Claude. Unset → that job's LLM disabled,
# template/skip fallback kicks in (never a crash).
ANTHROPIC_API_KEY=
# Google AI Studio key — https://aistudio.google.com/apikey
# Required whenever LLM_COMMENTARY_RATIONALE_PROVIDER, LLM_COMMENTARY_ALERT_PROVIDER,
# or GRAVITY_AI_RUNNER_ENABLED routes to Gemini. Also powers the AI Insights
# tab's Gemini Vision chart-pattern read. Unset → same graceful fallback.
GEMINI_API_KEY=
# OpenAI API key — https://platform.openai.com/api-keys
# Required only when OPAL_RESEARCH_ENABLED=true. Unset → Opal disabled, no
# research brief generated (byte-identical to a platform with Opal off).
OPENAI_API_KEY=

# ── Prompt Registry (prompt_registry/ package) ───────────────────────────────
# Versioned, cryptographically-signed, remotely-updatable store for every
# AI-facing instruction.  See docs/PROMPT_REGISTRY_PLAN.md for the full design.
#
# NON-SECRET tunables (GUI-writable from the Prompts tab via gui/env_io):
# ─────────────────────────────────────────────────────────────────────────────
# Master switch.  False (default) = baseline-only; zero network calls.
# Set True to enable remote manifest fetch.
PROMPT_REGISTRY_ENABLED=false

# Storage backend: "http" (default) | "local" | "firestore"
PROMPT_REGISTRY_BACKEND=http

# Signed-version disk cache location.  Relative to the repo root.
PROMPT_CACHE_DIR=output/prompt_cache

# Number of signed versions to keep on disk per prompt ID (offline rollback depth).
PROMPT_CACHE_KEEP_VERSIONS=5

# Hard upper bound on prompt body size enforced by guardrails.validate_prompt().
PROMPT_MAX_CHARS=50000

# Refresh interval in seconds (0 = launch-only / on-demand; CONSTRAINT #5).
PROMPT_REGISTRY_REFRESH_SECONDS=0

# Version pins — JSON object: {"master_preprompt": "1.2.0"}.
# Overrides the remote "latest" pointer per pinned ID.
# Managed by "python -m prompt_registry pin/rollback" or the GUI Prompts tab.
PROMPT_REGISTRY_PINS={}

# SECRET credentials (NOT GUI-writable; edit this file by hand only — CONSTRAINT #3):
# ─────────────────────────────────────────────────────────────────────────────
# Protected HTTPS URL of the signed manifest (private GitHub raw, S3, etc.).
PROMPT_REGISTRY_URL=

# Bearer read-token sent as "Authorization: Bearer <token>" to PROMPT_REGISTRY_URL.
PROMPT_REGISTRY_TOKEN=

# Higher-privilege publish credential — only needed on the machine that authors prompts.
# The runtime platform never needs this.
PROMPT_REGISTRY_PUBLISH_TOKEN=

# Shared HMAC-SHA256 key used to verify every fetched prompt body.
# A missing or mis-matched signature causes fail-closed fallback to cache → baseline.
PROMPT_REGISTRY_SIGNING_KEY=

# Credentials blob for the 'firestore' backend (only read when
# PROMPT_REGISTRY_BACKEND=firestore). Read directly via os.environ by
# prompt_registry/registry.py, not a settings.py Settings field.
PROMPT_REGISTRY_CREDENTIALS=
