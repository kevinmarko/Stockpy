# Credentials
credentials.json
secrets.py
.env

# Python caching
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual Environments
.venv/
env/
venv/

# IDE and OS
.DS_Store
.vscode/
*.code-workspace

# Debug output files / DB
*.csv
# Curated, version-controlled data fixtures (exceptions to the blanket *.csv rule).
# delisted_tickers.csv is a hand-maintained survivorship-bias fixture that
# universe_engine.get_delisted_tickers() and tests/test_universe.py depend on —
# without this exception a fresh clone / CI checkout cannot pass that test.
!data/delisted_tickers.csv
# ticker_sectors.csv is the committed symbol->yfinance-sector population map
# consumed by validation/sector_forecast_backtest.py and
# scripts/backtest_sector_configs.py — see forecasting_engine.py's
# sector_configs empirical-derivation pipeline.
!forecasting/data/ticker_sectors.csv
*.db
*.db-shm
*.db-wal
*.html
*.json
*.jsonl
!Gravity_Verification_Report.json
# The committed per-sector forecast config artifact, produced offline by
# scripts/backtest_sector_configs.py and loaded (with hardcoded fallback) by
# ForecastingEngine._load_sector_configs(). See validation/sector_config_io.py.
!forecasting/sector_configs.json

# Trained ML model artifacts — regenerated by scripts/train_lgbm.py and the
# monthly retraining job; never committed (the tracked ml/registry.yaml records
# the metrics/provenance instead). ml/models/.gitkeep + *.py stay tracked.
ml/models/*.pkl
# ML PIT feature-store cache artifacts (regenerated on demand; never committed)
ml/data/cache/

# S&P 500 universe cache — a 7-day-TTL Wikipedia-scrape cache regenerated by
# universe_engine.fetch_and_cache_universe()/_load_or_refresh_cache(). It
# mutates during normal pipeline operation (not just tests), so keeping it
# tracked risks the same merge-corruption failure class as quant_platform.db.
# data/delisted_tickers.csv (the hand-curated survivorship fixture) is
# unaffected and stays tracked.
data/universe_cache.parquet

# Scratch files
scratch_*.py
combined_code.*
pip install*.md

# Generated report output
/output/
