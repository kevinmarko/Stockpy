# Stockpy Pilots PWA — environment.
# Copy to `.env.local` to override. All keys are build-time (Vite `import.meta.env`).
#
# The one-click launcher (../launch_webapp.command) writes a `.env.local` for you
# in live mode. This file documents every knob for manual setups.

# ── The one flag that flips mock -> live ─────────────────────────────────────
# "true"  => run fully offline against src/api/mock.ts (no backend needed).
# "false" => hit the live APIs at the base URLs below.
VITE_USE_MOCK=true

# ── Backend origins (each is a SEPARATE FastAPI process) ─────────────────────
# The client routes by path prefix (src/api/client.ts baseFor):
#   /data/*        -> data_api    (:8603)
#   /metrics/*     -> metrics_api  (:8604)
#   /status,/run,/pipeline/*  -> control_api (:8601, daemon)
#   everything else -> pilots_api  (:8602)
# Each falls back to the Pilots base host if unset (single-origin reverse-proxy).
VITE_API_BASE_URL=http://localhost:8602
VITE_DATA_API_BASE_URL=http://localhost:8603
VITE_METRICS_API_BASE_URL=http://localhost:8604
VITE_CONTROL_API_BASE_URL=http://localhost:8601

# ── Auth ─────────────────────────────────────────────────────────────────────
# Sent as `Authorization: Bearer <token>` to EVERY backend. Set it equal to the
# backend's settings.STATE_API_TOKEN so read endpoints authorize (they 401 when
# the backend token is set but this is blank; they are fail-open only when the
# backend token is ALSO unset). To use "Follow", the backend must additionally
# set FOLLOW_API_TOKEN equal to STATE_API_TOKEN (the browser sends one token to
# all Pilots endpoints). Control-API write buttons (/run, /pipeline/*) need the
# separate ORCHESTRATOR_DAEMON_TOKEN and stay gated unless that equals this too.
VITE_API_TOKEN=
