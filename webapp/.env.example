# Stockpy Pilots PWA — environment.
# Copy to `.env.local` to override. All keys are build-time (Vite `import.meta.env`).

# Base URL of the live api/pilots_api.py FastAPI service.
VITE_API_BASE_URL=http://localhost:8602

# Bearer token sent as `Authorization: Bearer <token>` to the Pilots API.
# Matches settings.STATE_API_TOKEN on the backend (read endpoints are fail-open
# when unset; follow endpoints are fail-closed). Leave blank for local fail-open.
VITE_API_TOKEN=

# "true" => run fully offline against src/api/mock.ts (no backend needed).
# "false" => hit the live API at VITE_API_BASE_URL.
# THIS is the single flag that flips mock -> live.
VITE_USE_MOCK=true
