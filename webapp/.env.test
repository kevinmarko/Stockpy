# Forces mock mode for `npm test` / `vitest run` regardless of any local
# `.env.local` override (e.g. one auto-generated by launch_webapp.command in
# live mode). Vite loads .env.[mode] AFTER .env.local, so this wins for the
# same key when Vitest's mode is "test" — without touching .env.local itself.
#
# Why this exists: a real .env.local with VITE_USE_MOCK=false silently routed
# `npm test` at a live local backend instead of src/api/mock.ts's deterministic
# fixtures, producing non-reproducible test results with no error or warning.
# The "(real mock API)" test suites exist specifically to exercise the mock —
# this file makes that guarantee unconditional, not dependent on developer
# machine state.
VITE_USE_MOCK=true

# A real .env.local (see above) can also carry a real bearer token for local
# live-mode use. Left unset here, client.test.ts's "no token" test cases would
# otherwise silently pick up that real value instead of exercising the
# no-token branch. Individual tests still vi.stubEnv their own token value
# where a test specifically needs one -- this only fixes the shared baseline.
VITE_API_TOKEN=
